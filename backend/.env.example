# ============================================================
# Delta India Copy Trading System - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Supabase ----
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Delta Exchange Environment ----
# Set to 'demo' for testnet, 'live' for production
DELTA_ENV=demo

# ---- Delta Exchange Demo (Testnet) ----
DELTA_DEMO_REST_URL=https://cdn-ind.testnet.deltaex.org
DELTA_DEMO_WS_URL=wss://socket-ind.testnet.deltaex.org

# ---- Delta Exchange Live (Production) ----
DELTA_LIVE_REST_URL=https://api.india.delta.exchange
DELTA_LIVE_WS_URL=wss://socket.india.delta.exchange

# ---- CORS ----
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
